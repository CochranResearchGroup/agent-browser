{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-monitor-record.v1.schema.json",
  "title": "agent-browser service monitor record",
  "description": "Stable API shape for service-owned recurring heartbeat and freshness monitor records returned by HTTP service collection APIs and MCP resources.",
  "type": "object",
  "required": [
    "id",
    "name",
    "target",
    "intervalMs",
    "state",
    "lastCheckedAt",
    "lastSucceededAt",
    "lastFailedAt",
    "lastResult",
    "consecutiveFailures"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "target": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    },
    "intervalMs": {
      "type": "integer",
      "minimum": 1
    },
    "state": {
      "type": "string",
      "enum": ["active", "paused", "faulted"]
    },
    "lastCheckedAt": {
      "type": ["string", "null"]
    },
    "lastSucceededAt": {
      "type": ["string", "null"],
      "description": "Timestamp of the latest successful monitor probe, if any."
    },
    "lastFailedAt": {
      "type": ["string", "null"],
      "description": "Timestamp of the latest failed monitor probe, if any."
    },
    "lastResult": {
      "type": ["string", "null"]
    },
    "consecutiveFailures": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of failed probes since the latest successful probe."
    }
  },
  "additionalProperties": true
}
