{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-profile-lookup-response.v1.schema.json",
  "title": "agent-browser service profile lookup response",
  "description": "Stable API shape for server-authoritative service profile identity lookup returned by HTTP service APIs and service observability clients.",
  "type": "object",
  "required": [
    "query",
    "selectedProfile",
    "selectedProfileSource",
    "selectedProfileMatch",
    "readiness",
    "readinessSummary",
    "seedingHandoff"
  ],
  "properties": {
    "query": {
      "type": "object",
      "required": ["serviceName", "targetServiceIds", "accountIds", "url", "readinessProfileId", "browserBuild"],
      "properties": {
        "serviceName": {
          "type": ["string", "null"]
        },
        "targetServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "accountIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "url": {
          "type": ["string", "null"]
        },
        "readinessProfileId": {
          "type": ["string", "null"]
        },
        "browserBuild": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["stock_chrome", "stealthcdp_chromium", "cdp_free_headed"]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": true
    },
    "selectedProfile": {
      "oneOf": [
        {
          "$ref": "service-profile-record.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "selectedProfileSource": {
      "oneOf": [
        {
          "$ref": "service-profiles-response.v1.schema.json#/$defs/profileSource"
        },
        {
          "type": "null"
        }
      ]
    },
    "selectedProfileMatch": {
      "oneOf": [
        {
          "type": "object",
          "required": ["profileId", "profile", "reason", "matchedField", "matchedIdentity"],
          "properties": {
            "profileId": {
              "type": "string"
            },
            "profile": {
              "$ref": "service-profile-record.v1.schema.json"
            },
            "reason": {
              "type": "string",
              "enum": ["authenticated_target", "account_match", "target_match", "service_allow_list", "browser_build_default"]
            },
            "matchedField": {
              "oneOf": [
                {
                  "type": "string",
                  "enum": ["authenticatedServiceIds", "accountIds", "targetServiceIds", "sharedServiceIds", "browserBuild"]
                },
                {
                  "type": "null"
                }
              ]
            },
            "matchedIdentity": {
              "type": ["string", "null"]
            }
          },
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "readiness": {
      "oneOf": [
        {
          "$ref": "service-profile-readiness-response.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "readinessSummary": {
      "type": "object",
      "required": [
        "needsManualSeeding",
        "manualSeedingRequired",
        "targetServiceIds",
        "recommendedActions"
      ],
      "properties": {
        "needsManualSeeding": {
          "type": "boolean"
        },
        "manualSeedingRequired": {
          "type": "boolean"
        },
        "targetServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendedActions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "seedingHandoff": {
      "oneOf": [
        {
          "$ref": "service-profile-seeding-handoff-response.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": true
}
