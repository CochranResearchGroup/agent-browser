{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-reconcile-response.v1.schema.json",
  "title": "agent-browser service reconcile response",
  "description": "Stable API shape for service reconcile responses returned by CLI JSON and HTTP service APIs.",
  "type": "object",
  "required": [
    "reconciled",
    "browserCount",
    "changedBrowsers",
    "expiredSessionLeases",
    "expiredSessionLeaseCount",
    "remoteViewRepair",
    "service_state"
  ],
  "properties": {
    "reconciled": {
      "type": "boolean"
    },
    "browserCount": {
      "type": "integer",
      "minimum": 0
    },
    "changedBrowsers": {
      "type": "integer",
      "minimum": 0
    },
    "expiredSessionLeases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expiredSessionLeaseCount": {
      "type": "integer",
      "minimum": 0
    },
    "remoteViewRepair": {
      "type": "object",
      "required": [
        "orphanedDisplayAllocations",
        "orphanedRoutes",
        "releasedViewerLeases",
        "expiredViewerLeases",
        "clearedControllerLeases",
        "repaired",
        "released",
        "skippedUnsafe"
      ],
      "properties": {
        "orphanedDisplayAllocations": {
          "type": "integer",
          "minimum": 0
        },
        "orphanedRoutes": {
          "type": "integer",
          "minimum": 0
        },
        "releasedViewerLeases": {
          "type": "integer",
          "minimum": 0
        },
        "expiredViewerLeases": {
          "type": "integer",
          "minimum": 0
        },
        "clearedControllerLeases": {
          "type": "integer",
          "minimum": 0
        },
        "repaired": {
          "type": "integer",
          "minimum": 0
        },
        "released": {
          "type": "integer",
          "minimum": 0
        },
        "skippedUnsafe": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "service_state": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
