{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-status-response.v1.schema.json",
  "title": "agent-browser service status response",
  "description": "Stable API shape for service status responses returned by CLI JSON and HTTP service APIs.",
  "type": "object",
  "required": [
    "service_state",
    "profileAllocations"
  ],
  "properties": {
    "control_plane": {
      "type": "object",
      "properties": {
        "worker_state": {
          "type": "string"
        },
        "browser_health": {
          "type": "string"
        },
        "queue_depth": {
          "type": "integer",
          "minimum": 0
        },
        "queue_capacity": {
          "type": "integer",
          "minimum": 0
        },
        "waiting_profile_lease_job_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of retained service jobs currently waiting for profile lease release."
        },
        "service_job_timeout_ms": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "profileAllocations": {
      "description": "Derived service-owned profile allocation view for session holders and waiting profile-lease jobs.",
      "type": "array",
      "items": {
        "$ref": "service-profiles-response.v1.schema.json#/$defs/profileAllocation"
      }
    },
    "service_state": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
