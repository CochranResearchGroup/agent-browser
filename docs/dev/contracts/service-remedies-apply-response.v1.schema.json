{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-remedies-apply-response.v1.schema.json",
  "title": "agent-browser service remedies apply response",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "applied",
    "escalation",
    "count",
    "monitorIds",
    "monitorResults",
    "browserIds",
    "browserResults"
  ],
  "properties": {
    "applied": {
      "type": "boolean",
      "const": true
    },
    "escalation": {
      "type": "string",
      "enum": ["monitor_attention", "os_degraded_possible"]
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "monitorIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "monitorResults": {
      "type": "array",
      "items": {
        "$ref": "service-monitor-triage-response.v1.schema.json"
      }
    },
    "browserIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "browserResults": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "retryEnabled", "browser", "incident"],
        "properties": {
          "id": {
            "type": "string"
          },
          "retryEnabled": {
            "type": "boolean",
            "const": true
          },
          "browser": {
            "type": "object"
          },
          "incident": {
            "type": ["object", "null"]
          }
        }
      }
    }
  }
}
