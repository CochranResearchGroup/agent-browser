{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-profile-seeding-handoff-response.v1.schema.json",
  "title": "agent-browser service profile seeding handoff response",
  "description": "Stable API shape for an operator-ready profile seeding command and instructions derived from targetReadiness.",
  "type": "object",
  "required": [
    "profileId",
    "profileName",
    "targetServiceId",
    "loginId",
    "manualSeedingRequired",
    "seedingMode",
    "cdpAttachmentAllowedDuringSeeding",
    "preferredKeyring",
    "setupScopes",
    "recommendedAction",
    "url",
    "command",
    "lifecycle",
    "operatorSteps",
    "operatorIntervention",
    "warnings"
  ],
  "properties": {
    "profileId": {
      "type": "string"
    },
    "profileName": {
      "type": "string"
    },
    "targetServiceId": {
      "type": "string"
    },
    "loginId": {
      "type": ["string", "null"]
    },
    "manualSeedingRequired": {
      "type": "boolean"
    },
    "seedingMode": {
      "type": "string",
      "enum": ["not_required", "detached_headed_no_cdp", "attachable_ok"]
    },
    "cdpAttachmentAllowedDuringSeeding": {
      "type": "boolean"
    },
    "preferredKeyring": {
      "type": ["string", "null"],
      "enum": [
        "basic_password_store",
        "real_os_keychain",
        "managed_vault",
        "manual_login_profile",
        null
      ]
    },
    "setupScopes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["signin", "chrome_sync", "passkeys", "browser_plugins"]
      }
    },
    "recommendedAction": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "lifecycle": {
      "$ref": "#/$defs/profileSeedingHandoffLifecycle"
    },
    "operatorSteps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operatorIntervention": {
      "$ref": "#/$defs/operatorIntervention"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "profileSeedingHandoffLifecycle": {
      "type": "object",
      "required": [
        "id",
        "profileId",
        "targetServiceId",
        "state",
        "pid",
        "startedAt",
        "expiresAt",
        "lastPromptedAt",
        "declaredCompleteAt",
        "closedAt",
        "updatedAt",
        "actor",
        "note"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "profileId": {
          "type": "string"
        },
        "targetServiceId": {
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/profileSeedingHandoffState"
        },
        "pid": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "startedAt": {
          "type": ["string", "null"]
        },
        "expiresAt": {
          "type": ["string", "null"]
        },
        "lastPromptedAt": {
          "type": ["string", "null"]
        },
        "declaredCompleteAt": {
          "type": ["string", "null"]
        },
        "closedAt": {
          "type": ["string", "null"]
        },
        "updatedAt": {
          "type": ["string", "null"]
        },
        "actor": {
          "type": ["string", "null"]
        },
        "note": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "profileSeedingHandoffState": {
      "type": "string",
      "enum": [
        "not_required",
        "needs_manual_seeding",
        "seeding_launched_detached",
        "seeding_waiting_for_close",
        "completion_declared_waiting_for_close",
        "seeding_closed_unverified",
        "verification_pending",
        "fresh",
        "failed",
        "abandoned"
      ]
    },
    "operatorIntervention": {
      "description": "Machine-readable operator feedback contract for profile seeding. UI, desktop, webhook, and agent notifiers should render this state instead of inventing independent workflow rules.",
      "type": "object",
      "required": [
        "state",
        "severity",
        "title",
        "message",
        "ownedBy",
        "defaultChannels",
        "optionalChannels",
        "desktopPopupPolicy",
        "blocksProfileLease",
        "completionSignals",
        "actions"
      ],
      "properties": {
        "state": {
          "$ref": "#/$defs/profileSeedingHandoffState"
        },
        "severity": {
          "type": "string",
          "enum": ["info", "attention", "action_required", "danger"]
        },
        "title": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "ownedBy": {
          "type": "string",
          "enum": ["agent-browser"]
        },
        "defaultChannels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["api", "mcp", "dashboard", "desktop", "webhook", "agent"]
          }
        },
        "optionalChannels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["api", "mcp", "dashboard", "desktop", "webhook", "agent"]
          }
        },
        "desktopPopupPolicy": {
          "type": "string",
          "enum": ["disabled", "optional_policy_controlled", "required"]
        },
        "blocksProfileLease": {
          "type": "boolean"
        },
        "completionSignals": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "seeding_browser_closed",
              "operator_or_agent_declared_complete",
              "post_seeding_probe_records_freshness"
            ]
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/operatorInterventionAction"
          }
        }
      },
      "additionalProperties": true
    },
    "operatorInterventionAction": {
      "type": "object",
      "required": ["id", "label", "kind", "safety", "description"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "operator_command",
            "operator_instruction",
            "service_request",
            "operator_remedy"
          ]
        },
        "safety": {
          "type": "string",
          "enum": ["safe", "caution", "danger"]
        },
        "command": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
