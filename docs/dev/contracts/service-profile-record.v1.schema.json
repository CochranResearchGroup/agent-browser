{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-profile-record.v1.schema.json",
  "title": "agent-browser service profile record",
  "description": "Stable API shape for service profile records returned by HTTP service collection APIs and MCP resources.",
  "type": "object",
  "required": [
    "id",
    "name",
    "userDataDir",
    "sitePolicyIds",
    "targetServiceIds",
    "authenticatedServiceIds",
    "accountIds",
    "defaultBrowserHost",
    "allocation",
    "keyring",
    "sharedServiceIds",
    "credentialProviderIds",
    "manualLoginPreferred",
    "targetReadiness",
    "persistent",
    "tags"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "userDataDir": {
      "type": ["string", "null"]
    },
    "sitePolicyIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "targetServiceIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authenticatedServiceIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "accountIds": {
      "description": "Account identities this profile is intended to satisfy within target sites, for example a tenant slug, email address, or username.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "defaultBrowserHost": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "local_headless",
            "local_headed",
            "docker_headed",
            "remote_headed",
            "cloud_provider",
            "attached_existing"
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "allocation": {
      "type": "string",
      "enum": [
        "shared_service",
        "per_service",
        "per_site",
        "per_identity",
        "caller_supplied"
      ]
    },
    "keyring": {
      "type": "string",
      "enum": [
        "basic_password_store",
        "real_os_keychain",
        "managed_vault",
        "manual_login_profile"
      ]
    },
    "sharedServiceIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "credentialProviderIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "manualLoginPreferred": {
      "type": "boolean"
    },
    "targetReadiness": {
      "description": "Derived no-launch readiness rows for target services or login identities this profile may satisfy.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/profileTargetReadiness"
      }
    },
    "persistent": {
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "profileTargetReadiness": {
      "type": "object",
      "required": [
        "targetServiceId",
        "loginId",
        "state",
        "manualSeedingRequired",
        "evidence",
        "recommendedAction",
        "seedingMode",
        "cdpAttachmentAllowedDuringSeeding",
        "preferredKeyring",
        "setupScopes",
        "lastVerifiedAt",
        "freshnessExpiresAt"
      ],
      "properties": {
        "targetServiceId": {
          "type": "string"
        },
        "loginId": {
          "type": ["string", "null"]
        },
        "state": {
          "type": "string",
          "enum": [
            "unknown",
            "needs_manual_seeding",
            "seeded_unknown_freshness",
            "fresh",
            "stale",
            "blocked_by_attached_devtools"
          ]
        },
        "manualSeedingRequired": {
          "type": "boolean"
        },
        "evidence": {
          "type": "string"
        },
        "recommendedAction": {
          "type": "string"
        },
        "seedingMode": {
          "type": "string",
          "enum": ["not_required", "detached_headed_no_cdp", "attachable_ok"]
        },
        "cdpAttachmentAllowedDuringSeeding": {
          "type": "boolean"
        },
        "preferredKeyring": {
          "type": ["string", "null"],
          "enum": [
            "basic_password_store",
            "real_os_keychain",
            "managed_vault",
            "manual_login_profile",
            null
          ]
        },
        "setupScopes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["signin", "chrome_sync", "passkeys", "browser_plugins"]
          }
        },
        "lastVerifiedAt": {
          "type": ["string", "null"]
        },
        "freshnessExpiresAt": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
