{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-profile-record.v1.schema.json",
  "title": "agent-browser service profile record",
  "description": "Stable API shape for service profile records returned by HTTP service collection APIs and MCP resources.",
  "type": "object",
  "required": [
    "id",
    "name",
    "profileOrigin",
    "userDataDir",
    "sitePolicyIds",
    "targetServiceIds",
    "authenticatedServiceIds",
    "accountIds",
    "defaultBrowserHost",
    "browserBuild",
    "allocation",
    "keyring",
    "sharedServiceIds",
    "credentialProviderIds",
    "manualLoginPreferred",
    "targetReadiness",
    "registration",
    "browserCompatibilityEvidence",
    "persistent",
    "tags"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "profileOrigin": {
      "description": "Ownership boundary for the profile user-data directory and cleanup policy.",
      "type": "string",
      "enum": ["agent_browser_owned", "external_byop", "external_observed"]
    },
    "userDataDir": {
      "type": ["string", "null"]
    },
    "sitePolicyIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "targetServiceIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authenticatedServiceIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "accountIds": {
      "description": "Account identities this profile is intended to satisfy within target sites, for example a tenant slug, email address, or username.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "defaultBrowserHost": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "local_headless",
            "local_headed",
            "docker_headed",
            "remote_headed",
            "cloud_provider",
            "attached_existing"
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "browserBuild": {
      "description": "Preferred browser build for this profile, or null when the service default should decide.",
      "oneOf": [
        {
          "type": "string",
          "enum": ["stock_chrome", "stealthcdp_chromium", "cdp_free_headed"]
        },
        {
          "type": "null"
        }
      ]
    },
    "allocation": {
      "type": "string",
      "enum": [
        "shared_service",
        "per_service",
        "per_site",
        "per_identity",
        "caller_supplied"
      ]
    },
    "keyring": {
      "type": "string",
      "enum": [
        "basic_password_store",
        "real_os_keychain",
        "managed_vault",
        "manual_login_profile"
      ]
    },
    "sharedServiceIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "credentialProviderIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "manualLoginPreferred": {
      "type": "boolean"
    },
    "targetReadiness": {
      "description": "Derived no-launch readiness rows for target services or login identities this profile may satisfy.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/profileTargetReadiness"
      }
    },
    "registration": {
      "description": "Explicit BYOP or observed-profile registration metadata.",
      "oneOf": [
        {
          "$ref": "#/$defs/profileRegistration"
        },
        {
          "type": "null"
        }
      ]
    },
    "browserCompatibilityEvidence": {
      "description": "Browser family/build evidence recorded when an external profile is registered.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/browserCompatibilityEvidence"
      }
    },
    "persistent": {
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "profileRegistration": {
      "type": "object",
      "required": [
        "serviceName",
        "agentName",
        "targetServiceIds",
        "accountIds",
        "registeredAt",
        "source"
      ],
      "properties": {
        "serviceName": {
          "type": ["string", "null"]
        },
        "agentName": {
          "type": ["string", "null"]
        },
        "targetServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "accountIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "registeredAt": {
          "type": ["string", "null"]
        },
        "source": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "browserCompatibilityEvidence": {
      "type": "object",
      "required": [
        "browserFamily",
        "browserBuild",
        "browserVersion",
        "evidence",
        "observedAt",
        "source"
      ],
      "properties": {
        "browserFamily": {
          "type": ["string", "null"]
        },
        "browserBuild": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["stock_chrome", "stealthcdp_chromium", "cdp_free_headed"]
            },
            {
              "type": "null"
            }
          ]
        },
        "browserVersion": {
          "type": ["string", "null"]
        },
        "evidence": {
          "type": "string"
        },
        "observedAt": {
          "type": ["string", "null"]
        },
        "source": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "profileTargetReadiness": {
      "type": "object",
      "required": [
        "targetServiceId",
        "loginId",
        "state",
        "manualSeedingRequired",
        "evidence",
        "recommendedAction",
        "seedingMode",
        "cdpAttachmentAllowedDuringSeeding",
        "preferredKeyring",
        "setupScopes",
        "lastVerifiedAt",
        "freshnessExpiresAt"
      ],
      "properties": {
        "targetServiceId": {
          "type": "string"
        },
        "loginId": {
          "type": ["string", "null"]
        },
        "state": {
          "type": "string",
          "enum": [
            "unknown",
            "needs_manual_seeding",
            "seeded_unknown_freshness",
            "fresh",
            "stale",
            "blocked_by_attached_devtools"
          ]
        },
        "manualSeedingRequired": {
          "type": "boolean"
        },
        "evidence": {
          "type": "string"
        },
        "recommendedAction": {
          "type": "string"
        },
        "seedingMode": {
          "type": "string",
          "enum": ["not_required", "detached_headed_no_cdp", "attachable_ok"]
        },
        "cdpAttachmentAllowedDuringSeeding": {
          "type": "boolean"
        },
        "preferredKeyring": {
          "type": ["string", "null"],
          "enum": [
            "basic_password_store",
            "real_os_keychain",
            "managed_vault",
            "manual_login_profile",
            null
          ]
        },
        "setupScopes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["signin", "chrome_sync", "passkeys", "browser_plugins"]
          }
        },
        "lastVerifiedAt": {
          "type": ["string", "null"]
        },
        "freshnessExpiresAt": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
