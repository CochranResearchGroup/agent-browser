{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-events-response.v1.schema.json",
  "title": "agent-browser service events response",
  "description": "Stable API shape for filtered service event list responses returned by CLI JSON and HTTP service APIs.",
  "type": "object",
  "required": [
    "events",
    "count",
    "matched",
    "total"
  ],
  "properties": {
    "events": {
      "type": "array"
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "matched": {
      "type": "integer",
      "minimum": 0
    },
    "total": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": true
}
