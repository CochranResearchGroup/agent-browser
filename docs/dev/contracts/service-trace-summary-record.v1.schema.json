{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-trace-summary-record.v1.schema.json",
  "title": "agent-browser service trace summary record",
  "description": "Stable API shape for service trace summary records returned by CLI JSON, HTTP service APIs, MCP tools, and dashboard trace views.",
  "type": "object",
  "required": [
    "contextCount",
    "hasTraceContext",
    "namingWarningCount",
    "browserCapabilityLaunches",
    "profileLeaseWaits",
    "contexts"
  ],
  "properties": {
    "contextCount": {
      "type": "integer",
      "minimum": 0
    },
    "hasTraceContext": {
      "type": "boolean"
    },
    "namingWarningCount": {
      "type": "integer",
      "minimum": 0
    },
    "browserCapabilityLaunches": {
      "type": "object",
      "required": [
        "count",
        "appliedCount",
        "skippedCount",
        "launches"
      ],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "appliedCount": {
          "type": "integer",
          "minimum": 0
        },
        "skippedCount": {
          "type": "integer",
          "minimum": 0
        },
        "launches": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "source",
              "timestamp",
              "serviceName",
              "agentName",
              "taskName",
              "browserId",
              "profileId",
              "sessionId",
              "applied",
              "reason",
              "browserBuild",
              "bindingId",
              "hostId",
              "executableId",
              "capabilityId",
              "executablePath"
            ],
            "properties": {
              "source": {
                "type": "string",
                "enum": ["event", "session"]
              },
              "timestamp": {
                "type": ["string", "null"],
                "format": "date-time"
              },
              "serviceName": {
                "type": ["string", "null"]
              },
              "agentName": {
                "type": ["string", "null"]
              },
              "taskName": {
                "type": ["string", "null"]
              },
              "browserId": {
                "type": ["string", "null"]
              },
              "profileId": {
                "type": ["string", "null"]
              },
              "sessionId": {
                "type": ["string", "null"]
              },
              "applied": {
                "type": "boolean"
              },
              "reason": {
                "type": ["string", "null"]
              },
              "browserBuild": {
                "type": ["string", "null"]
              },
              "bindingId": {
                "type": ["string", "null"]
              },
              "hostId": {
                "type": ["string", "null"]
              },
              "executableId": {
                "type": ["string", "null"]
              },
              "capabilityId": {
                "type": ["string", "null"]
              },
              "executablePath": {
                "type": ["string", "null"]
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "profileLeaseWaits": {
      "type": "object",
      "required": [
        "count",
        "activeCount",
        "completedCount",
        "waits"
      ],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "activeCount": {
          "type": "integer",
          "minimum": 0
        },
        "completedCount": {
          "type": "integer",
          "minimum": 0
        },
        "waits": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "jobId",
              "profileId",
              "outcome",
              "startedAt",
              "endedAt",
              "waitedMs",
              "retryAfterMs",
              "conflictSessionIds",
              "serviceName",
              "agentName",
              "taskName"
            ],
            "properties": {
              "jobId": {
                "type": "string"
              },
              "profileId": {
                "type": ["string", "null"]
              },
              "outcome": {
                "type": "string"
              },
              "startedAt": {
                "type": ["string", "null"],
                "format": "date-time"
              },
              "endedAt": {
                "type": ["string", "null"],
                "format": "date-time"
              },
              "waitedMs": {
                "type": ["integer", "null"],
                "minimum": 0
              },
              "retryAfterMs": {
                "type": ["integer", "null"],
                "minimum": 0
              },
              "conflictSessionIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "serviceName": {
                "type": ["string", "null"]
              },
              "agentName": {
                "type": ["string", "null"]
              },
              "taskName": {
                "type": ["string", "null"]
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "contexts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "serviceName",
          "agentName",
          "taskName",
          "browserId",
          "profileId",
          "sessionId",
          "namingWarnings",
          "hasNamingWarning",
          "eventCount",
          "jobCount",
          "incidentCount",
          "activityCount",
          "targetIdentityCount",
          "targetServiceIds",
          "controlPlaneModes",
          "lifecycleOnlyJobCount",
          "latestTimestamp"
        ],
        "properties": {
          "serviceName": {
            "type": ["string", "null"]
          },
          "agentName": {
            "type": ["string", "null"]
          },
          "taskName": {
            "type": ["string", "null"]
          },
          "browserId": {
            "type": ["string", "null"]
          },
          "profileId": {
            "type": ["string", "null"]
          },
          "sessionId": {
            "type": ["string", "null"]
          },
          "namingWarnings": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "missing_service_name",
                "missing_agent_name",
                "missing_task_name"
              ]
            },
            "uniqueItems": true
          },
          "hasNamingWarning": {
            "type": "boolean"
          },
          "eventCount": {
            "type": "integer",
            "minimum": 0
          },
          "jobCount": {
            "type": "integer",
            "minimum": 0
          },
          "incidentCount": {
            "type": "integer",
            "minimum": 0
          },
          "activityCount": {
            "type": "integer",
            "minimum": 0
          },
          "targetIdentityCount": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of normalized target-service, site, and login identity hints represented by this trace context."
          },
          "targetServiceIds": {
            "type": "array",
            "description": "Normalized target-service, site, and login identity hints observed on retained jobs in this trace context.",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "controlPlaneModes": {
            "type": "array",
            "description": "Control-plane modes observed on retained jobs in this trace context.",
            "items": {
              "type": "string",
              "enum": [
                "cdp",
                "cdp_free",
                "service"
              ]
            },
            "uniqueItems": true
          },
          "lifecycleOnlyJobCount": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of lifecycle-only retained jobs in this trace context."
          },
          "latestTimestamp": {
            "type": ["string", "null"],
            "format": "date-time"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
