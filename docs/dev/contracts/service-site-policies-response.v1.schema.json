{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-site-policies-response.v1.schema.json",
  "title": "agent-browser service site policies response",
  "description": "Stable API shape for compact service site policy collection responses returned by CLI JSON, HTTP service APIs, and MCP resources.",
  "type": "object",
  "required": [
    "sitePolicies",
    "sitePolicySources",
    "count"
  ],
  "properties": {
    "sitePolicies": {
      "type": "array"
    },
    "sitePolicySources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "overrideable", "precedence"],
        "properties": {
          "id": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": ["config", "persisted_state", "builtin"]
          },
          "overrideable": {
            "type": "boolean"
          },
          "precedence": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["config", "persisted_state", "builtin"]
            }
          }
        },
        "additionalProperties": true
      }
    },
    "count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": true
}
