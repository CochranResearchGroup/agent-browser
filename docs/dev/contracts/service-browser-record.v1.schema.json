{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-browser-record.v1.schema.json",
  "title": "agent-browser service browser record",
  "description": "Stable API shape for service browser records returned by HTTP service collection APIs and MCP resources.",
  "type": "object",
  "required": [
    "id",
    "profileId",
    "host",
    "health",
    "pid",
    "cdpEndpoint",
    "viewStreams",
    "activeSessionIds",
    "tabHandles",
    "lastError",
    "lastHealthObservation"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "profileId": {
      "type": ["string", "null"]
    },
    "host": {
      "type": "string",
      "enum": [
        "local_headless",
        "local_headed",
        "docker_headed",
        "remote_headed",
        "cloud_provider",
        "attached_existing"
      ]
    },
    "health": {
      "type": "string",
      "enum": [
        "not_started",
        "launching",
        "ready",
        "degraded",
        "unreachable",
        "process_exited",
        "cdp_disconnected",
        "reconnecting",
        "closing",
        "faulted"
      ]
    },
    "displayIsolation": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "private_virtual_display",
            "shared_display",
            "ambient_display"
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "displayName": {
      "type": ["string", "null"]
    },
    "displayAllocationId": {
      "description": "Service-owned display allocation id when the browser is bound to an explicit remote display allocation.",
      "type": ["string", "null"]
    },
    "pid": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "cdpEndpoint": {
      "type": ["string", "null"]
    },
    "viewStreams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "provider",
          "readOnly"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "provider": {
            "type": "string",
            "enum": [
              "cdp_screencast",
              "chrome_tab_webrtc",
              "virtual_display_webrtc",
              "novnc",
              "rdp_gateway",
              "external_url"
            ]
          },
          "controlInput": {
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "cdp_input",
                  "webrtc_input",
                  "vnc_input",
                  "manual_attached_desktop"
                ]
              },
              {
                "type": "null"
              }
            ]
          },
          "url": {
            "type": [
              "string",
              "null"
            ]
          },
          "frameUrl": {
            "description": "Dashboard-embeddable stream URL selected by the service.",
            "type": [
              "string",
              "null"
            ]
          },
          "externalUrl": {
            "description": "Direct stream URL for external windows or popout viewers.",
            "type": [
              "string",
              "null"
            ]
          },
          "routeId": {
            "description": "Service-owned route identifier for providers that multiplex viewers.",
            "type": [
              "string",
              "null"
            ]
          },
          "displayAllocationId": {
            "description": "Service-owned display allocation id used by this stream route.",
            "type": [
              "string",
              "null"
            ]
          },
          "connectionId": {
            "description": "Provider connection id or route token, such as a Guacamole client id.",
            "type": [
              "string",
              "null"
            ]
          },
          "connectionName": {
            "description": "Human-readable provider connection name, when known.",
            "type": [
              "string",
              "null"
            ]
          },
          "routeSource": {
            "description": "Source that selected the route metadata.",
            "type": [
              "string",
              "null"
            ]
          },
          "providerMode": {
            "description": "Provider viewer concurrency mode for this route.",
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "simultaneous_view",
              "single_viewer",
              "single_controller",
              "unknown",
              "unavailable",
              null
            ]
          },
          "viewerLeaseIds": {
            "description": "Active or retained viewer leases associated with this route.",
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "controllerLeaseId": {
            "description": "Current controller lease for this stream route, when known.",
            "type": [
              "string",
              "null"
            ]
          },
          "readOnly": {
            "type": "boolean"
          },
          "readiness": {
            "description": "Optional compact provider readiness payload for this stream.",
            "type": ["object", "array", "null"]
          },
          "remoteReadiness": {
            "description": "Optional remote-provider readiness payload for this stream.",
            "type": ["object", "array", "null"]
          },
          "attachability": {
            "description": "Derived browser-first reattach state for RDP streams, including recommended action and route/display/proof agreement evidence.",
            "type": ["object", "null"]
          }
        },
        "additionalProperties": true
      }
    },
    "activeSessionIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tabHandles": {
      "description": "Derived service-owned tab handles currently associated with this browser.",
      "type": "array",
      "items": {
        "$ref": "service-tab-record.v1.schema.json#/$defs/serviceTabHandle"
      }
    },
    "attachability": {
      "description": "Derived browser-first reattach state for retained remote-headed browsers, including recommended action and route/display/proof agreement evidence.",
      "type": ["object", "null"]
    },
    "lastError": {
      "type": ["string", "null"]
    },
    "lastHealthObservation": {
      "type": ["object", "null"]
    }
  },
  "additionalProperties": true
}
