{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-tab-record.v1.schema.json",
  "title": "agent-browser service tab record",
  "description": "Stable API shape for service tab records returned by HTTP service collection APIs and MCP resources.",
  "type": "object",
  "required": [
    "id",
    "browserId",
    "targetId",
    "sessionId",
    "lifecycle",
    "url",
    "title",
    "ownerSessionId",
    "serviceTabHandle",
    "latestSnapshotId",
    "latestScreenshotId",
    "challengeId"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "browserId": {
      "type": "string"
    },
    "targetId": {
      "type": ["string", "null"]
    },
    "sessionId": {
      "type": ["string", "null"]
    },
    "lifecycle": {
      "type": "string",
      "enum": [
        "unknown",
        "opening",
        "loading",
        "ready",
        "closing",
        "closed",
        "crashed"
      ]
    },
    "url": {
      "type": ["string", "null"]
    },
    "title": {
      "type": ["string", "null"]
    },
    "ownerSessionId": {
      "type": ["string", "null"]
    },
    "serviceTabHandle": {
      "oneOf": [
        {
          "$ref": "#/$defs/serviceTabHandle"
        },
        {
          "type": "null"
        }
      ]
    },
    "latestSnapshotId": {
      "type": ["string", "null"]
    },
    "latestScreenshotId": {
      "type": ["string", "null"]
    },
    "challengeId": {
      "type": ["string", "null"]
    }
  },
  "$defs": {
    "serviceTabHandleTraceFilter": {
      "type": "object",
      "required": ["browserId", "profileId", "sessionId"],
      "properties": {
        "browserId": {
          "type": ["string", "null"]
        },
        "profileId": {
          "type": ["string", "null"]
        },
        "sessionId": {
          "type": ["string", "null"]
        },
        "serviceName": {
          "type": ["string", "null"],
          "description": "Calling service label that owns the tab evidence context, when known."
        },
        "agentName": {
          "type": ["string", "null"],
          "description": "Calling agent label that owns the tab evidence context, when known."
        },
        "taskName": {
          "type": ["string", "null"],
          "description": "Calling task label that owns the tab evidence context, when known."
        }
      },
      "additionalProperties": true
    },
    "serviceTabHandle": {
      "type": "object",
      "required": [
        "browserId",
        "sessionName",
        "tabId",
        "targetId",
        "url",
        "title",
        "profileId",
        "profileOrigin",
        "leaseId",
        "leaseState",
        "cleanupPolicy",
        "leaseHeartbeatExpected",
        "ownerSessionId",
        "jobId",
        "traceFilter",
        "valid",
        "staleReason"
      ],
      "properties": {
        "browserId": {
          "type": "string"
        },
        "sessionName": {
          "type": ["string", "null"]
        },
        "tabId": {
          "type": "string"
        },
        "targetId": {
          "type": ["string", "null"]
        },
        "url": {
          "type": ["string", "null"]
        },
        "title": {
          "type": ["string", "null"]
        },
        "profileId": {
          "type": ["string", "null"]
        },
        "profileOrigin": {
          "type": "string",
          "enum": ["agent_browser_owned", "external_byop", "external_observed"]
        },
        "leaseId": {
          "type": ["string", "null"]
        },
        "leaseState": {
          "type": ["string", "null"],
          "enum": ["shared", "exclusive", "human_takeover", "released", "expired", null]
        },
        "cleanupPolicy": {
          "type": ["string", "null"],
          "enum": ["detach", "close_tabs", "close_browser", "release_only", null]
        },
        "leaseHeartbeatExpected": {
          "type": "boolean"
        },
        "ownerSessionId": {
          "type": ["string", "null"]
        },
        "jobId": {
          "type": ["string", "null"]
        },
        "traceFilter": {
          "$ref": "#/$defs/serviceTabHandleTraceFilter"
        },
        "valid": {
          "type": "boolean"
        },
        "staleReason": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
