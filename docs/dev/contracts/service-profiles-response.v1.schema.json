{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-profiles-response.v1.schema.json",
  "title": "agent-browser service profiles response",
  "description": "Stable API shape for compact service profile collection responses returned by CLI JSON, HTTP service APIs, and MCP resources.",
  "type": "object",
  "required": [
    "profiles",
    "profileSources",
    "profileAllocations",
    "count"
  ],
  "properties": {
    "profiles": {
      "type": "array"
    },
    "profileSources": {
      "description": "Source metadata for each effective profile row after config, runtime observation, and persisted state have been layered.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/profileSource"
      }
    },
    "profileAllocations": {
      "description": "Derived service-owned profile allocation view for session holders and waiting profile-lease jobs.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/profileAllocation"
      }
    },
    "count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "profileSource": {
      "type": "object",
      "required": [
        "id",
        "source",
        "overrideable",
        "precedence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": ["config", "runtime_observed", "persisted_state"]
        },
        "overrideable": {
          "type": "boolean"
        },
        "precedence": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["config", "runtime_observed", "persisted_state"]
          }
        }
      },
      "additionalProperties": true
    },
    "profileAllocation": {
      "type": "object",
      "required": [
        "profileId",
        "profileName",
        "allocation",
        "keyring",
        "browserBuild",
        "targetServiceIds",
        "authenticatedServiceIds",
        "accountIds",
        "targetReadiness",
        "sharedServiceIds",
        "holderSessionIds",
        "holderCount",
        "exclusiveHolderSessionIds",
        "waitingJobIds",
        "waitingJobCount",
        "conflictSessionIds",
        "leaseState",
        "recommendedAction",
        "serviceNames",
        "agentNames",
        "taskNames",
        "browserIds",
        "browserSummaries",
        "tabIds"
      ],
      "properties": {
        "profileId": {
          "type": "string"
        },
        "profileName": {
          "type": "string"
        },
        "allocation": {
          "type": "string"
        },
        "keyring": {
          "type": "string"
        },
        "browserBuild": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["stock_chrome", "stealthcdp_chromium", "cdp_free_headed"]
            },
            {
              "type": "null"
            }
          ]
        },
        "targetServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "authenticatedServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "accountIds": {
          "description": "Account identities this profile is intended to satisfy within target sites.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "targetReadiness": {
          "description": "Derived no-launch readiness rows for target services or login identities this profile may satisfy.",
          "type": "array",
          "items": {
            "$ref": "service-profile-record.v1.schema.json#/$defs/profileTargetReadiness"
          }
        },
        "sharedServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "holderSessionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "holderCount": {
          "type": "integer",
          "minimum": 0
        },
        "exclusiveHolderSessionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "waitingJobIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "waitingJobCount": {
          "type": "integer",
          "minimum": 0
        },
        "conflictSessionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "leaseState": {
          "type": "string",
          "enum": ["available", "shared", "exclusive", "waiting", "conflicted"]
        },
        "recommendedAction": {
          "type": "string"
        },
        "serviceNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agentNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "taskNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "browserIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "browserSummaries": {
          "description": "Compact service-owned browser state for browsers currently associated with this profile allocation.",
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "browserId",
              "host",
              "health",
              "pid",
              "hasCdpEndpoint",
              "activeSessionIds"
            ],
            "properties": {
              "browserId": {
                "type": "string"
              },
              "host": {
                "type": "string",
                "enum": [
                  "local_headless",
                  "local_headed",
                  "docker_headed",
                  "remote_headed",
                  "cloud_provider",
                  "attached_existing"
                ]
              },
              "health": {
                "type": "string",
                "enum": [
                  "not_started",
                  "launching",
                  "ready",
                  "degraded",
                  "unreachable",
                  "process_exited",
                  "cdp_disconnected",
                  "reconnecting",
                  "closing",
                  "faulted"
                ]
              },
              "pid": {
                "type": ["integer", "null"],
                "minimum": 0
              },
              "hasCdpEndpoint": {
                "type": "boolean"
              },
              "activeSessionIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "tabIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
