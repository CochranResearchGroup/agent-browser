{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-profiles-response.v1.schema.json",
  "title": "agent-browser service profiles response",
  "description": "Stable API shape for compact service profile collection responses returned by CLI JSON, HTTP service APIs, and MCP resources.",
  "type": "object",
  "required": [
    "profiles",
    "profileAllocations",
    "count"
  ],
  "properties": {
    "profiles": {
      "type": "array"
    },
    "profileAllocations": {
      "description": "Derived service-owned profile allocation view for session holders and waiting profile-lease jobs.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/profileAllocation"
      }
    },
    "count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "profileAllocation": {
      "type": "object",
      "required": [
        "profileId",
        "profileName",
        "allocation",
        "keyring",
        "targetServiceIds",
        "authenticatedServiceIds",
        "targetReadiness",
        "sharedServiceIds",
        "holderSessionIds",
        "holderCount",
        "exclusiveHolderSessionIds",
        "waitingJobIds",
        "waitingJobCount",
        "conflictSessionIds",
        "leaseState",
        "recommendedAction",
        "serviceNames",
        "agentNames",
        "taskNames",
        "browserIds",
        "tabIds"
      ],
      "properties": {
        "profileId": {
          "type": "string"
        },
        "profileName": {
          "type": "string"
        },
        "allocation": {
          "type": "string"
        },
        "keyring": {
          "type": "string"
        },
        "targetServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "authenticatedServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "targetReadiness": {
          "description": "Derived no-launch readiness rows for target services or login identities this profile may satisfy.",
          "type": "array",
          "items": {
            "$ref": "service-profile-record.v1.schema.json#/$defs/profileTargetReadiness"
          }
        },
        "sharedServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "holderSessionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "holderCount": {
          "type": "integer",
          "minimum": 0
        },
        "exclusiveHolderSessionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "waitingJobIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "waitingJobCount": {
          "type": "integer",
          "minimum": 0
        },
        "conflictSessionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "leaseState": {
          "type": "string",
          "enum": ["available", "shared", "exclusive", "waiting", "conflicted"]
        },
        "recommendedAction": {
          "type": "string"
        },
        "serviceNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agentNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "taskNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "browserIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tabIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
