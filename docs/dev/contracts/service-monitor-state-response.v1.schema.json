{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-monitor-state-response.v1.schema.json",
  "title": "agent-browser service monitor state response",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "monitor", "state", "updated"],
  "properties": {
    "id": {
      "type": "string"
    },
    "monitor": {
      "$ref": "service-monitor-record.v1.schema.json"
    },
    "state": {
      "type": "string",
      "enum": ["active", "paused", "faulted"]
    },
    "updated": {
      "type": "boolean",
      "const": true
    }
  }
}
