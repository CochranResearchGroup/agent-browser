{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-monitors-response.v1.schema.json",
  "title": "agent-browser service monitors response",
  "description": "Stable API shape for compact service monitor collection responses returned by CLI JSON, HTTP service APIs, and MCP resources.",
  "type": "object",
  "required": [
    "monitors",
    "count"
  ],
  "properties": {
    "monitors": {
      "type": "array"
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "matched": {
      "type": "integer",
      "minimum": 0
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "filters": {
      "type": "object",
      "properties": {
        "state": {
          "type": ["string", "null"],
          "enum": ["active", "paused", "faulted", null]
        },
        "failedOnly": {
          "type": "boolean"
        },
        "summary": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "active": {
          "type": "integer",
          "minimum": 0
        },
        "paused": {
          "type": "integer",
          "minimum": 0
        },
        "faulted": {
          "type": "integer",
          "minimum": 0
        },
        "failing": {
          "type": "integer",
          "minimum": 0
        },
        "repeatedFailures": {
          "type": "integer",
          "minimum": 0
        },
        "neverChecked": {
          "type": "integer",
          "minimum": 0
        },
        "failingMonitorIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repeatedFailureMonitorIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "neverCheckedMonitorIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lastFailedAt": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
