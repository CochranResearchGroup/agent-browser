{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-job-record.v1.schema.json",
  "title": "agent-browser service job record",
  "description": "Stable API shape for service job records returned by CLI JSON, HTTP service APIs, MCP resources, and service traces.",
  "type": "object",
  "required": [
    "id",
    "action",
    "serviceName",
    "agentName",
    "taskName",
    "namingWarnings",
    "hasNamingWarning",
    "controlPlaneMode",
    "lifecycleOnly",
    "target",
    "owner",
    "state",
    "priority",
    "submittedAt",
    "startedAt",
    "completedAt",
    "timeoutMs",
    "result",
    "error"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "serviceName": {
      "type": ["string", "null"]
    },
    "agentName": {
      "type": ["string", "null"]
    },
    "taskName": {
      "type": ["string", "null"]
    },
    "targetServiceId": {
      "type": ["string", "null"],
      "description": "Singular target service or identity-provider hint supplied by the caller."
    },
    "siteId": {
      "type": ["string", "null"],
      "description": "Singular site hint supplied by the caller."
    },
    "loginId": {
      "type": ["string", "null"],
      "description": "Singular login identity hint supplied by the caller."
    },
    "targetServiceIds": {
      "type": "array",
      "description": "Normalized target-service, site, and login identity hints used for profile selection.",
      "items": {
        "type": "string"
      }
    },
    "namingWarnings": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "missing_service_name",
          "missing_agent_name",
          "missing_task_name"
        ]
      },
      "uniqueItems": true
    },
    "hasNamingWarning": {
      "type": "boolean",
      "description": "True when namingWarnings is non-empty."
    },
    "controlPlaneMode": {
      "type": "string",
      "enum": [
        "cdp",
        "cdp_free",
        "service"
      ],
      "description": "Control-plane attachment posture required for this job."
    },
    "lifecycleOnly": {
      "type": "boolean",
      "description": "True when the job manages browser, profile, monitor, or service lifecycle rather than a CDP-backed tab interaction."
    },
    "target": {
      "oneOf": [
        {
          "const": "service"
        },
        {
          "type": "object"
        }
      ]
    },
    "owner": {},
    "state": {
      "type": "string",
      "enum": [
        "queued",
        "waiting_profile_lease",
        "running",
        "succeeded",
        "failed",
        "cancelled",
        "timed_out"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "lifecycle"
      ]
    },
    "submittedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "startedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "timeoutMs": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "result": {},
    "error": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": true
}
