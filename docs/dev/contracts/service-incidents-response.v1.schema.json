{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-incidents-response.v1.schema.json",
  "title": "agent-browser service incidents response",
  "description": "Stable API shape for filtered service incident list and detail responses returned by CLI JSON, HTTP service APIs, and MCP service_incidents.",
  "type": "object",
  "required": [
    "incidents",
    "count",
    "matched",
    "total"
  ],
  "properties": {
    "filters": {
      "type": "object",
      "required": [
        "state",
        "severity",
        "escalation",
        "handlingState",
        "kind",
        "browserId",
        "profileId",
        "sessionId",
        "serviceName",
        "agentName",
        "taskName",
        "since",
        "remediesOnly",
        "limit"
      ],
      "properties": {
        "state": {
          "type": ["string", "null"],
          "enum": [
            "active",
            "recovered",
            "service",
            null
          ]
        },
        "severity": {
          "type": ["string", "null"],
          "enum": [
            "info",
            "warning",
            "error",
            "critical",
            null
          ]
        },
        "escalation": {
          "type": ["string", "null"],
          "enum": [
            "none",
            "browser_recovery",
            "browser_degraded",
            "job_attention",
            "monitor_attention",
            "service_triage",
            "os_degraded_possible",
            null
          ]
        },
        "handlingState": {
          "type": ["string", "null"],
          "enum": [
            "open",
            "acknowledged",
            "resolved",
            null
          ]
        },
        "kind": {
          "type": ["string", "null"]
        },
        "browserId": {
          "type": ["string", "null"]
        },
        "profileId": {
          "type": ["string", "null"]
        },
        "sessionId": {
          "type": ["string", "null"]
        },
        "serviceName": {
          "type": ["string", "null"]
        },
        "agentName": {
          "type": ["string", "null"]
        },
        "taskName": {
          "type": ["string", "null"]
        },
        "since": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "remediesOnly": {
          "type": "boolean",
          "description": "True when the response is narrowed to browser_degraded and os_degraded_possible operator remedy groups."
        },
        "limit": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "incident": {
      "type": "object"
    },
    "incidents": {
      "type": "array"
    },
    "events": {
      "type": "array"
    },
    "jobs": {
      "type": "array"
    },
    "summary": {
      "type": "object",
      "description": "Optional compact incident grouping returned when summary output is requested.",
      "required": [
        "groupCount",
        "groups"
      ],
      "properties": {
        "groupCount": {
          "type": "integer",
          "minimum": 0
        },
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "escalation",
              "severity",
              "state",
              "count",
              "latestTimestamp",
              "recommendedAction",
              "incidentIds",
              "monitorIds"
            ],
            "properties": {
              "escalation": {
                "type": "string"
              },
              "severity": {
                "type": "string"
              },
              "state": {
                "type": "string"
              },
              "count": {
                "type": "integer",
                "minimum": 0
              },
              "latestTimestamp": {
                "type": "string"
              },
              "recommendedAction": {
                "type": "string"
              },
              "incidentIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "monitorIds": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Monitor ids represented in this group when incidents came from failed monitor probes."
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "matched": {
      "type": "integer",
      "minimum": 0
    },
    "total": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": true
}
