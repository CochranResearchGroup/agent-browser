{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-access-plan-response.v1.schema.json",
  "title": "agent-browser service access plan response",
  "description": "Stable API shape for the no-launch service-owned access recommendation returned by HTTP service APIs, MCP resources, and service observability clients.",
  "type": "object",
  "required": [
    "query",
    "selectedProfile",
    "selectedProfileSource",
    "selectedProfileMatch",
    "readiness",
    "readinessSummary",
    "sitePolicy",
    "sitePolicySource",
    "providers",
    "challenges",
    "decision"
  ],
  "properties": {
    "query": {
      "type": "object",
      "required": [
        "serviceName",
        "agentName",
        "taskName",
        "targetServiceIds",
        "sitePolicyId",
        "challengeId",
        "readinessProfileId",
        "namingWarnings",
        "hasNamingWarning"
      ],
      "properties": {
        "serviceName": {
          "type": ["string", "null"]
        },
        "agentName": {
          "type": ["string", "null"]
        },
        "taskName": {
          "type": ["string", "null"]
        },
        "targetServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sitePolicyId": {
          "type": ["string", "null"]
        },
        "challengeId": {
          "type": ["string", "null"]
        },
        "readinessProfileId": {
          "type": ["string", "null"]
        },
        "namingWarnings": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["missing_service_name", "missing_agent_name", "missing_task_name"]
          }
        },
        "hasNamingWarning": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "selectedProfile": {
      "oneOf": [
        {
          "$ref": "service-profile-record.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "selectedProfileSource": {
      "oneOf": [
        {
          "$ref": "service-profiles-response.v1.schema.json#/$defs/profileSource"
        },
        {
          "type": "null"
        }
      ]
    },
    "selectedProfileMatch": {
      "oneOf": [
        {
          "type": "object",
          "required": ["profileId", "profile", "reason", "matchedField", "matchedIdentity"],
          "properties": {
            "profileId": {
              "type": "string"
            },
            "profile": {
              "$ref": "service-profile-record.v1.schema.json"
            },
            "reason": {
              "type": "string",
              "enum": ["authenticated_target", "target_match", "service_allow_list"]
            },
            "matchedField": {
              "oneOf": [
                {
                  "type": "string",
                  "enum": ["authenticatedServiceIds", "targetServiceIds", "sharedServiceIds"]
                },
                {
                  "type": "null"
                }
              ]
            },
            "matchedIdentity": {
              "type": ["string", "null"]
            }
          },
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "readiness": {
      "oneOf": [
        {
          "$ref": "service-profile-readiness-response.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "readinessSummary": {
      "type": "object",
      "required": [
        "needsManualSeeding",
        "manualSeedingRequired",
        "targetServiceIds",
        "recommendedActions"
      ],
      "properties": {
        "needsManualSeeding": {
          "type": "boolean"
        },
        "manualSeedingRequired": {
          "type": "boolean"
        },
        "targetServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendedActions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "sitePolicy": {
      "oneOf": [
        {
          "$ref": "service-site-policy-record.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "sitePolicySource": {
      "oneOf": [
        {
          "type": "object",
          "required": ["id", "source", "matchedBy", "overrideable", "precedence"],
          "properties": {
            "id": {
              "type": "string"
            },
            "source": {
              "type": "string",
              "enum": ["config", "persisted_state", "builtin"]
            },
            "matchedBy": {
              "type": "string",
              "enum": [
                "explicit_site_policy_id",
                "target_service_id",
                "profile_site_policy_id"
              ]
            },
            "overrideable": {
              "type": "boolean"
            },
            "precedence": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["config", "persisted_state", "builtin"]
              }
            }
          },
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "providers": {
      "type": "array",
      "items": {
        "$ref": "service-provider-record.v1.schema.json"
      }
    },
    "challenges": {
      "type": "array",
      "items": {
        "$ref": "service-challenge-record.v1.schema.json"
      }
    },
    "decision": {
      "type": "object",
      "required": [
        "recommendedAction",
        "browserHost",
        "launchPosture",
        "interactionMode",
        "interactionRisk",
        "pacing",
        "challengePolicy",
        "profileId",
        "manualActionRequired",
        "manualSeedingRequired",
        "providerIds",
        "authProviderIds",
        "challengeProviderIds",
        "missingChallengeCapabilities",
        "challengeStrategy",
        "challengeIds",
        "freshnessUpdate",
        "namingWarnings",
        "hasNamingWarning",
        "reasons"
      ],
      "properties": {
        "recommendedAction": {
          "type": "string"
        },
        "browserHost": {
          "type": "string",
          "enum": [
            "local_headless",
            "local_headed",
            "docker_headed",
            "remote_headed",
            "cloud_provider",
            "attached_existing"
          ]
        },
        "launchPosture": {
          "type": "object",
          "required": [
            "browserHost",
            "source",
            "headed",
            "remoteViewRecommended",
            "detachedFirstLoginRequired",
            "attachableAfterSeeding",
            "rationale"
          ],
          "properties": {
            "browserHost": {
              "type": "string",
              "enum": [
                "local_headless",
                "local_headed",
                "docker_headed",
                "remote_headed",
                "cloud_provider",
                "attached_existing"
              ]
            },
            "source": {
              "type": "string",
              "enum": ["site_policy", "profile_default", "service_default"]
            },
            "headed": {
              "type": "boolean"
            },
            "remoteViewRecommended": {
              "type": "boolean"
            },
            "detachedFirstLoginRequired": {
              "type": "boolean"
            },
            "attachableAfterSeeding": {
              "type": "boolean"
            },
            "rationale": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "interactionMode": {
          "type": ["string", "null"]
        },
        "interactionRisk": {
          "type": "string",
          "enum": ["standard", "hardened", "manual"]
        },
        "pacing": {
          "type": "object",
          "required": [
            "minActionDelayMs",
            "jitterMs",
            "cooldownMs",
            "maxParallelSessions",
            "retryBudget",
            "rateLimited",
            "jittered",
            "singleSessionRecommended"
          ],
          "properties": {
            "minActionDelayMs": {
              "type": "integer",
              "minimum": 0
            },
            "jitterMs": {
              "type": "integer",
              "minimum": 0
            },
            "cooldownMs": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "maxParallelSessions": {
              "type": ["integer", "null"],
              "minimum": 1
            },
            "retryBudget": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "rateLimited": {
              "type": "boolean"
            },
            "jittered": {
              "type": "boolean"
            },
            "singleSessionRecommended": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "challengePolicy": {
          "type": ["string", "null"]
        },
        "profileId": {
          "type": ["string", "null"]
        },
        "manualActionRequired": {
          "type": "boolean"
        },
        "manualSeedingRequired": {
          "type": "boolean"
        },
        "providerIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "authProviderIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "challengeProviderIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missingChallengeCapabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "password_fill",
              "passkey",
              "totp_code",
              "sms_code",
              "email_code",
              "visual_reasoning",
              "captcha_solve",
              "human_approval"
            ]
          }
        },
        "challengeStrategy": {
          "type": "string",
          "enum": [
            "deny",
            "none",
            "manual_only",
            "provider_preferred",
            "provider_allowed",
            "avoid_first",
            "missing_provider",
            "manual_review"
          ]
        },
        "challengeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "freshnessUpdate": {
          "type": "object",
          "required": [
            "available",
            "recommendedAfterProbe",
            "profileId",
            "targetServiceIds",
            "http",
            "mcp",
            "client",
            "requestFields"
          ],
          "properties": {
            "available": {
              "type": "boolean"
            },
            "recommendedAfterProbe": {
              "type": "boolean"
            },
            "profileId": {
              "type": ["string", "null"]
            },
            "targetServiceIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "http": {
              "type": "object",
              "required": ["method", "route", "routeTemplate"],
              "properties": {
                "method": {
                  "type": "string",
                  "enum": ["POST"]
                },
                "route": {
                  "type": ["string", "null"]
                },
                "routeTemplate": {
                  "type": "string",
                  "enum": ["/api/service/profiles/<id>/freshness"]
                }
              },
              "additionalProperties": true
            },
            "mcp": {
              "type": "object",
              "required": ["tool"],
              "properties": {
                "tool": {
                  "type": "string",
                  "enum": ["service_profile_freshness_update"]
                }
              },
              "additionalProperties": true
            },
            "client": {
              "type": "object",
              "required": ["package", "helper"],
              "properties": {
                "package": {
                  "type": "string",
                  "enum": ["@agent-browser/client/service-observability"]
                },
                "helper": {
                  "type": "string",
                  "enum": ["updateServiceProfileFreshness"]
                }
              },
              "additionalProperties": true
            },
            "requestFields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "namingWarnings": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["missing_service_name", "missing_agent_name", "missing_task_name"]
          }
        },
        "hasNamingWarning": {
          "type": "boolean"
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
