{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-browser.local/contracts/service-access-plan-response.v1.schema.json",
  "title": "agent-browser service access plan response",
  "description": "Stable API shape for the no-launch service-owned access recommendation returned by HTTP service APIs, MCP resources, and service observability clients.",
  "type": "object",
  "required": [
    "query",
    "selectedProfile",
    "selectedProfileSource",
    "selectedProfileMatch",
    "readiness",
    "readinessSummary",
    "seedingHandoff",
    "monitorFindings",
    "sitePolicy",
    "sitePolicySource",
    "providers",
    "challenges",
    "browserCapabilityEvidence",
    "decision"
  ],
  "properties": {
    "query": {
      "type": "object",
      "required": [
        "serviceName",
        "agentName",
        "taskName",
        "targetServiceIds",
        "accountIds",
        "url",
        "sitePolicyId",
        "challengeId",
        "readinessProfileId",
        "browserBuild",
        "namingWarnings",
        "hasNamingWarning"
      ],
      "properties": {
        "serviceName": {
          "type": ["string", "null"]
        },
        "agentName": {
          "type": ["string", "null"]
        },
        "taskName": {
          "type": ["string", "null"]
        },
        "targetServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "accountIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "url": {
          "type": ["string", "null"]
        },
        "sitePolicyId": {
          "type": ["string", "null"]
        },
        "challengeId": {
          "type": ["string", "null"]
        },
        "readinessProfileId": {
          "type": ["string", "null"]
        },
        "browserBuild": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["stock_chrome", "stealthcdp_chromium", "cdp_free_headed"]
            },
            {
              "type": "null"
            }
          ]
        },
        "namingWarnings": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["missing_service_name", "missing_agent_name", "missing_task_name"]
          }
        },
        "hasNamingWarning": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "selectedProfile": {
      "oneOf": [
        {
          "$ref": "service-profile-record.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "selectedProfileSource": {
      "oneOf": [
        {
          "$ref": "service-profiles-response.v1.schema.json#/$defs/profileSource"
        },
        {
          "type": "null"
        }
      ]
    },
    "selectedProfileMatch": {
      "oneOf": [
        {
          "type": "object",
          "required": ["profileId", "profile", "reason", "matchedField", "matchedIdentity"],
          "properties": {
            "profileId": {
              "type": "string"
            },
            "profile": {
              "$ref": "service-profile-record.v1.schema.json"
            },
            "reason": {
              "type": "string",
              "enum": ["authenticated_target", "account_match", "target_match", "service_allow_list", "browser_build_default"]
            },
            "matchedField": {
              "oneOf": [
                {
                  "type": "string",
                  "enum": ["authenticatedServiceIds", "accountIds", "targetServiceIds", "sharedServiceIds", "browserBuild"]
                },
                {
                  "type": "null"
                }
              ]
            },
            "matchedIdentity": {
              "type": ["string", "null"]
            }
          },
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "readiness": {
      "oneOf": [
        {
          "$ref": "service-profile-readiness-response.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "readinessSummary": {
      "type": "object",
      "required": [
        "needsManualSeeding",
        "manualSeedingRequired",
        "targetServiceIds",
        "recommendedActions"
      ],
      "properties": {
        "needsManualSeeding": {
          "type": "boolean"
        },
        "manualSeedingRequired": {
          "type": "boolean"
        },
        "targetServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendedActions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "seedingHandoff": {
      "oneOf": [
        {
          "$ref": "service-profile-seeding-handoff-response.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "monitorFindings": {
      "type": "object",
      "required": [
        "profileReadinessAttentionRequired",
        "profileReadinessProbeDue",
        "profileReadinessIncidentIds",
        "profileReadinessMonitorIds",
        "profileReadinessDueMonitorIds",
        "profileReadinessNeverCheckedMonitorIds",
        "profileReadinessResults",
        "targetServiceIds",
        "dueTargetServiceIds"
      ],
      "properties": {
        "profileReadinessAttentionRequired": {
          "type": "boolean"
        },
        "profileReadinessProbeDue": {
          "type": "boolean"
        },
        "profileReadinessIncidentIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profileReadinessMonitorIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profileReadinessDueMonitorIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profileReadinessNeverCheckedMonitorIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profileReadinessResults": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "targetServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dueTargetServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "sitePolicy": {
      "oneOf": [
        {
          "$ref": "service-site-policy-record.v1.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "sitePolicySource": {
      "oneOf": [
        {
          "type": "object",
          "required": ["id", "source", "matchedBy", "overrideable", "precedence"],
          "properties": {
            "id": {
              "type": "string"
            },
            "source": {
              "type": "string",
              "enum": ["config", "persisted_state", "builtin"]
            },
            "matchedBy": {
              "type": "string",
              "enum": [
                "explicit_site_policy_id",
                "target_service_id",
                "profile_site_policy_id"
              ]
            },
            "overrideable": {
              "type": "boolean"
            },
            "precedence": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["config", "persisted_state", "builtin"]
              }
            }
          },
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "providers": {
      "type": "array",
      "items": {
        "$ref": "service-provider-record.v1.schema.json"
      }
    },
    "challenges": {
      "type": "array",
      "items": {
        "$ref": "service-challenge-record.v1.schema.json"
      }
    },
    "browserCapabilityEvidence": {
      "description": "Advisory browser capability registry evidence relevant to this access-plan request. Preference bindings can influence the access-plan browser build recommendation when no explicit, site-policy, or profile browser build has already won; scheduler launch routing does not consume the registry directly yet.",
      "type": "object",
      "required": [
        "advisory",
        "routingApplied",
        "routingScope",
        "source",
        "browserBuild",
        "browserBuildLabel",
        "selectedProfileId",
        "selectedPreferenceBinding",
        "targetServiceIds",
        "accountIds",
        "serviceName",
        "taskName",
        "generatedAt",
        "browserHosts",
        "browserExecutables",
        "browserCapabilities",
        "profileCompatibility",
        "browserPreferenceBindings",
        "validationEvidence",
        "counts",
        "notes"
      ],
      "properties": {
        "advisory": {
          "type": "boolean",
          "const": true
        },
        "routingApplied": {
          "type": "boolean"
        },
        "routingScope": {
          "type": "string",
          "enum": ["none", "access_plan_recommendation"]
        },
        "source": {
          "type": "string",
          "const": "service.browserCapabilityRegistry"
        },
        "browserBuild": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["stock_chrome", "stealthcdp_chromium", "cdp_free_headed"]
            },
            {
              "type": "null"
            }
          ]
        },
        "browserBuildLabel": {
          "type": ["string", "null"],
          "enum": ["stock_chrome", "stealthcdp_chromium", "cdp_free_headed", null]
        },
        "selectedProfileId": {
          "type": ["string", "null"]
        },
        "selectedPreferenceBinding": {
          "oneOf": [
            {
              "$ref": "service-browser-capability-registry.v1.schema.json#/$defs/browserPreferenceBinding"
            },
            {
              "type": "null"
            }
          ]
        },
        "targetServiceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "accountIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "serviceName": {
          "type": ["string", "null"]
        },
        "taskName": {
          "type": ["string", "null"]
        },
        "generatedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "browserHosts": {
          "type": "array",
          "items": {
            "$ref": "service-browser-capability-registry.v1.schema.json#/$defs/browserHost"
          }
        },
        "browserExecutables": {
          "type": "array",
          "items": {
            "$ref": "service-browser-capability-registry.v1.schema.json#/$defs/browserExecutable"
          }
        },
        "browserCapabilities": {
          "type": "array",
          "items": {
            "$ref": "service-browser-capability-registry.v1.schema.json#/$defs/browserCapability"
          }
        },
        "profileCompatibility": {
          "type": "array",
          "items": {
            "$ref": "service-browser-capability-registry.v1.schema.json#/$defs/profileCompatibility"
          }
        },
        "browserPreferenceBindings": {
          "type": "array",
          "items": {
            "$ref": "service-browser-capability-registry.v1.schema.json#/$defs/browserPreferenceBinding"
          }
        },
        "validationEvidence": {
          "type": "array",
          "items": {
            "$ref": "service-browser-capability-registry.v1.schema.json#/$defs/browserValidationEvidence"
          }
        },
        "counts": {
          "type": "object",
          "required": [
            "browserHosts",
            "browserExecutables",
            "browserCapabilities",
            "profileCompatibility",
            "browserPreferenceBindings",
            "validationEvidence"
          ],
          "properties": {
            "browserHosts": {
              "type": "integer",
              "minimum": 0
            },
            "browserExecutables": {
              "type": "integer",
              "minimum": 0
            },
            "browserCapabilities": {
              "type": "integer",
              "minimum": 0
            },
            "profileCompatibility": {
              "type": "integer",
              "minimum": 0
            },
            "browserPreferenceBindings": {
              "type": "integer",
              "minimum": 0
            },
            "validationEvidence": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": true
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "decision": {
      "type": "object",
      "required": [
        "recommendedAction",
        "browserHost",
        "launchPosture",
        "interactionMode",
        "interactionRisk",
        "pacing",
        "challengePolicy",
        "profileId",
        "manualActionRequired",
        "manualSeedingRequired",
        "monitorAttentionRequired",
        "monitorProbeDue",
        "providerIds",
        "authProviderIds",
        "challengeProviderIds",
        "missingChallengeCapabilities",
        "challengeStrategy",
        "challengeIds",
        "freshnessUpdate",
        "postSeedingProbe",
        "monitorRunDue",
        "serviceRequest",
        "namingWarnings",
        "hasNamingWarning",
        "reasons"
      ],
      "properties": {
        "recommendedAction": {
          "type": "string"
        },
        "browserHost": {
          "type": "string",
          "enum": [
            "local_headless",
            "local_headed",
            "docker_headed",
            "remote_headed",
            "cloud_provider",
            "attached_existing"
          ]
        },
        "launchPosture": {
          "type": "object",
          "required": [
            "browserHost",
            "browserBuild",
            "browserBuildSource",
            "source",
            "headed",
            "remoteViewRecommended",
            "requiresCdpFree",
            "cdpAttachmentAllowed",
            "detachedFirstLoginRequired",
            "attachableAfterSeeding",
            "rationale"
          ],
          "properties": {
            "browserHost": {
              "type": "string",
              "enum": [
                "local_headless",
                "local_headed",
                "docker_headed",
                "remote_headed",
                "cloud_provider",
                "attached_existing"
              ]
            },
            "browserBuild": {
              "type": "string",
              "enum": [
                "stock_chrome",
                "stealthcdp_chromium",
                "cdp_free_headed"
              ]
            },
            "browserBuildSource": {
              "type": "string",
              "enum": [
                "request",
                "site_policy",
                "profile_default",
                "browser_preference_binding",
                "requires_cdp_free",
                "service_default"
              ]
            },
            "source": {
              "type": "string",
              "enum": ["site_policy", "profile_default", "service_default"]
            },
            "headed": {
              "type": "boolean"
            },
            "remoteViewRecommended": {
              "type": "boolean"
            },
            "requiresCdpFree": {
              "type": "boolean"
            },
            "cdpAttachmentAllowed": {
              "type": "boolean"
            },
            "detachedFirstLoginRequired": {
              "type": "boolean"
            },
            "attachableAfterSeeding": {
              "type": "boolean"
            },
            "rationale": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "interactionMode": {
          "type": ["string", "null"]
        },
        "interactionRisk": {
          "type": "string",
          "enum": ["standard", "hardened", "manual"]
        },
        "pacing": {
          "type": "object",
          "required": [
            "minActionDelayMs",
            "jitterMs",
            "cooldownMs",
            "maxParallelSessions",
            "retryBudget",
            "rateLimited",
            "jittered",
            "singleSessionRecommended"
          ],
          "properties": {
            "minActionDelayMs": {
              "type": "integer",
              "minimum": 0
            },
            "jitterMs": {
              "type": "integer",
              "minimum": 0
            },
            "cooldownMs": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "maxParallelSessions": {
              "type": ["integer", "null"],
              "minimum": 1
            },
            "retryBudget": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "rateLimited": {
              "type": "boolean"
            },
            "jittered": {
              "type": "boolean"
            },
            "singleSessionRecommended": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "challengePolicy": {
          "type": ["string", "null"]
        },
        "profileId": {
          "type": ["string", "null"]
        },
        "manualActionRequired": {
          "type": "boolean"
        },
        "manualSeedingRequired": {
          "type": "boolean"
        },
        "monitorAttentionRequired": {
          "type": "boolean"
        },
        "monitorProbeDue": {
          "type": "boolean"
        },
        "providerIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "authProviderIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "challengeProviderIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missingChallengeCapabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "password_fill",
              "passkey",
              "totp_code",
              "sms_code",
              "email_code",
              "visual_reasoning",
              "captcha_solve",
              "human_approval"
            ]
          }
        },
        "challengeStrategy": {
          "type": "string",
          "enum": [
            "deny",
            "none",
            "manual_only",
            "provider_preferred",
            "provider_allowed",
            "avoid_first",
            "missing_provider",
            "manual_review"
          ]
        },
        "challengeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "freshnessUpdate": {
          "type": "object",
          "required": [
            "available",
            "recommendedAfterProbe",
            "profileId",
            "targetServiceIds",
            "http",
            "mcp",
            "client",
            "requestFields"
          ],
          "properties": {
            "available": {
              "type": "boolean"
            },
            "recommendedAfterProbe": {
              "type": "boolean"
            },
            "profileId": {
              "type": ["string", "null"]
            },
            "targetServiceIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "http": {
              "type": "object",
              "required": ["method", "route", "routeTemplate"],
              "properties": {
                "method": {
                  "type": "string",
                  "enum": ["POST"]
                },
                "route": {
                  "type": ["string", "null"]
                },
                "routeTemplate": {
                  "type": "string",
                  "enum": ["/api/service/profiles/<id>/freshness"]
                }
              },
              "additionalProperties": true
            },
            "mcp": {
              "type": "object",
              "required": ["tool"],
              "properties": {
                "tool": {
                  "type": "string",
                  "enum": ["service_profile_freshness_update"]
                }
              },
              "additionalProperties": true
            },
            "client": {
              "type": "object",
              "required": ["package", "helper"],
              "properties": {
                "package": {
                  "type": "string",
                  "enum": ["@agent-browser/client/service-observability"]
                },
                "helper": {
                  "type": "string",
                  "enum": ["updateServiceProfileFreshness"]
                }
              },
              "additionalProperties": true
            },
            "requestFields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "serviceRequest": {
          "type": "object",
          "required": [
            "available",
            "recommendedAfterManualAction",
            "blockedByManualAction",
            "blockedByCdpFree",
            "blockedByPolicy",
            "requiresCdpFree",
            "cdpAttachmentAllowed",
            "action",
            "selectedProfileId",
            "profileLeasePolicy",
            "request",
            "http",
            "mcp",
            "client",
            "requestFields"
          ],
          "properties": {
            "available": {
              "type": "boolean"
            },
            "recommendedAfterManualAction": {
              "type": "boolean"
            },
            "blockedByManualAction": {
              "type": "boolean"
            },
            "blockedByCdpFree": {
              "type": "boolean"
            },
            "blockedByPolicy": {
              "type": "boolean"
            },
            "requiresCdpFree": {
              "type": "boolean"
            },
            "cdpAttachmentAllowed": {
              "type": "boolean"
            },
            "action": {
              "type": "string",
              "enum": ["tab_new"]
            },
            "selectedProfileId": {
              "type": ["string", "null"]
            },
            "profileLeasePolicy": {
              "type": "string",
              "enum": ["wait"]
            },
            "request": {
              "type": "object",
              "required": ["action", "profileLeasePolicy"],
              "properties": {
                "action": {
                  "type": "string",
                  "enum": ["tab_new"]
                },
                "serviceName": {
                  "type": "string"
                },
                "agentName": {
                  "type": "string"
                },
                "taskName": {
                  "type": "string"
                },
                "targetServiceIds": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "profileLeasePolicy": {
                  "type": "string",
                  "enum": ["wait"]
                },
                "requiresCdpFree": {
                  "type": "boolean"
                },
                "cdpAttachmentAllowed": {
                  "type": "boolean"
                }
              },
              "additionalProperties": true
            },
            "http": {
              "type": "object",
              "required": ["method", "route"],
              "properties": {
                "method": {
                  "type": "string",
                  "enum": ["POST"]
                },
                "route": {
                  "type": "string",
                  "enum": ["/api/service/request"]
                }
              },
              "additionalProperties": true
            },
            "mcp": {
              "type": "object",
              "required": ["tool"],
              "properties": {
                "tool": {
                  "type": "string",
                  "enum": ["service_request"]
                }
              },
              "additionalProperties": true
            },
            "client": {
              "type": "object",
              "required": ["package", "helper"],
              "properties": {
                "package": {
                  "type": "string",
                  "enum": ["@agent-browser/client/service-request"]
                },
                "helper": {
                  "type": "string",
                  "enum": ["requestServiceTab"]
                }
              },
              "additionalProperties": true
            },
            "requestFields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "monitorRunDue": {
          "type": "object",
          "required": [
            "available",
            "recommendedBeforeUse",
            "monitorIds",
            "neverCheckedMonitorIds",
            "targetServiceIds",
            "http",
            "mcp",
            "client",
            "fallbackClient",
            "cli",
            "requestFields",
            "notes"
          ],
          "properties": {
            "available": {
              "type": "boolean"
            },
            "recommendedBeforeUse": {
              "type": "boolean"
            },
            "monitorIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "neverCheckedMonitorIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "targetServiceIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "http": {
              "type": "object",
              "required": ["method", "route"],
              "properties": {
                "method": {
                  "type": "string",
                  "enum": ["POST"]
                },
                "route": {
                  "type": "string",
                  "enum": ["/api/service/monitors/run-due"]
                }
              },
              "additionalProperties": true
            },
            "mcp": {
              "type": "object",
              "required": ["tool"],
              "properties": {
                "tool": {
                  "type": "string",
                  "enum": ["service_monitors_run_due"]
